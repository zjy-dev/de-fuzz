# 图 4 — 大模型约束求解主循环（四·技术路线 §3 末）
# 渲染：d2 --layout=elk --pad=24 main-loop.d2 main-loop.svg

direction: down

run: "Run\nload seeds + coverage map" {
  shape: oval
  style: { fill: white; stroke: "#6B7280"; stroke-width: 2; font-color: "#111827" }
}

pick: "Pick Target BB\nuncovered, max successors" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

build: "Build Context\nfn source + line marks + predecessor seeds" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

prompt: "Assemble Prompt\nbase + invariant contract" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

llm: "LLM Mutate" {
  shape: cloud
  style: { fill: "#EDE9FE"; stroke: "#7C3AED"; stroke-width: 3; font-color: "#111827"; bold: true }
}

compile: "Compile?" {
  shape: diamond
  style: { fill: "#FEF3C7"; stroke: "#D97706"; stroke-width: 2; font-color: "#111827" }
}

hit: "Hit Target?" {
  shape: diamond
  style: { fill: "#FEF3C7"; stroke: "#D97706"; stroke-width: 2; font-color: "#111827" }
}

oracle: "Oracle Check" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6; bold: true }
}

decision: "Three-way Decision\nCoveredNew · HitTarget · Bug" {
  shape: diamond
  style: { fill: "#FEF3C7"; stroke: "#D97706"; stroke-width: 2; font-color: "#111827" }
}

keep: "Keep in Corpus" {
  shape: oval
  style: { fill: "#DCFCE7"; stroke: "#4A9F65"; stroke-width: 2; font-color: "#111827"; bold: true }
}

drop: "Drop" {
  shape: oval
  style: { fill: "#E5E7EB"; stroke: "#9CA3AF"; stroke-width: 2; font-color: "#374151" }
}

fix: "Compile-error\nfeedback" {
  style: { fill: "#FFF7ED"; stroke: "#F2994A"; stroke-width: 2; font-color: "#9A3412"; border-radius: 6; bold: true }
}

refine: "uftrace + Divergent-fn\nrefinement" {
  style: { fill: "#FFF7ED"; stroke: "#F2994A"; stroke-width: 2; font-color: "#9A3412"; border-radius: 6; bold: true }
}

# main chain
run -> pick { style: { stroke: "#374151"; stroke-width: 2 } }
pick -> build { style: { stroke: "#374151"; stroke-width: 2 } }
build -> prompt { style: { stroke: "#374151"; stroke-width: 2 } }
prompt -> llm { style: { stroke: "#374151"; stroke-width: 2 } }
llm -> compile { style: { stroke: "#374151"; stroke-width: 2 } }
compile -> hit: "ok" { style: { stroke: "#374151"; stroke-width: 2 } }
hit -> oracle: "yes" { style: { stroke: "#374151"; stroke-width: 2 } }
oracle -> decision { style: { stroke: "#374151"; stroke-width: 2 } }
decision -> keep: "ok" { style: { stroke: "#4A9F65"; stroke-width: 2 } }
decision -> drop: "fail" { style: { stroke: "#9CA3AF"; stroke-width: 2 } }

# feedback loops (orange dashed)
compile -> fix: "fail" { style: { stroke: "#F2994A"; stroke-width: 2; stroke-dash: 5 } }
fix -> llm: "compile error" { style: { stroke: "#F2994A"; stroke-width: 2; stroke-dash: 5 } }
hit -> refine: "no" { style: { stroke: "#F2994A"; stroke-width: 2; stroke-dash: 5 } }
refine -> llm: "divergence refine" { style: { stroke: "#F2994A"; stroke-width: 2; stroke-dash: 5 } }

# next iter (single dashed loop back to picker, label kept short)
keep -> pick: "next iter" { style: { stroke: "#9CA3AF"; stroke-width: 2; stroke-dash: 5 } }
