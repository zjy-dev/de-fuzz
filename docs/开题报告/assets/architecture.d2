# 图 2 — DeFuzz 总体架构（四·技术路线 §1 末）
# 渲染：d2 --layout=elk --pad=24 architecture.d2 architecture.svg

direction: right

cli: "DeFuzz CLI" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

engine: "Engine\nfuzz main loop" {
  style: { fill: "#DBEAFE"; stroke: "#3B82F6"; stroke-width: 3; font-color: "#111827"; border-radius: 6; bold: true }
}

prompt: "PromptService\nbase + invariant contract" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

llm: "Remote LLM" {
  shape: cloud
  style: { fill: "#EDE9FE"; stroke: "#7C3AED"; stroke-width: 2; font-color: "#111827"; bold: true }
}

compiler: "Compiler\nGCC / LLVM (instrumented)" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

cov: "Coverage Analyzer\n.gcda / .profraw → line cov" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

oracle: "Mechanism Oracle\n3-phase invariant check" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

inspector: "Binary Inspector\nELF symbols / patterns" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

exec: "Executor\nnative / qemu-user" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

corpus: "Seed Corpus" {
  shape: cylinder
  style: { fill: "#F4F8FB"; stroke: "#6B7280"; stroke-width: 2; font-color: "#374151"; bold: true }
}

flag: "FlagScheduler\npositive / negative profile" {
  style: { fill: white; stroke: "#D1D5DB"; stroke-width: 2; font-color: "#111827"; border-radius: 6 }
}

cli -> engine { style: { stroke: "#374151"; stroke-width: 2 } }
engine -> prompt { style: { stroke: "#374151"; stroke-width: 2 } }
prompt -> llm { style: { stroke: "#374151"; stroke-width: 2 } }
llm -> engine { style: { stroke: "#374151"; stroke-width: 2 } }
engine -> compiler { style: { stroke: "#374151"; stroke-width: 2 } }
compiler -> cov { style: { stroke: "#374151"; stroke-width: 2 } }
cov -> engine { style: { stroke: "#374151"; stroke-width: 2 } }
engine -> oracle { style: { stroke: "#374151"; stroke-width: 2 } }
oracle -> engine { style: { stroke: "#374151"; stroke-width: 2 } }
oracle -> inspector { style: { stroke: "#374151"; stroke-width: 2 } }
oracle -> exec { style: { stroke: "#374151"; stroke-width: 2 } }
engine -> corpus { style: { stroke: "#374151"; stroke-width: 2 } }
flag -> oracle: "polarity" { style: { stroke: "#9CA3AF"; stroke-width: 2; stroke-dash: 5 } }
flag -> compiler: "compile flags" { style: { stroke: "#9CA3AF"; stroke-width: 2; stroke-dash: 5 } }
