# Figure 3 — research content dependency chain (English)
# render: d2 --layout=dagre --pad=24 pipeline.en.d2 pipeline.en.svg

direction: right

step1: "" {
  grid-rows: 4
  grid-gap: 8
  style: {
    fill: "#FEE2E2"; stroke: "#DC2626"; stroke-width: 3
    border-radius: 12
  }

  title: "Defense Invariants" {
    shape: text
    style: { font-color: "#991B1B"; bold: true }
  }
  s1: "Official docs" {
    style: { fill: white; stroke: "#DC2626"; stroke-width: 2; font-color: "#991B1B"; border-radius: 6 }
  }
  s2: "Source comments" {
    style: { fill: white; stroke: "#DC2626"; stroke-width: 2; font-color: "#991B1B"; border-radius: 6 }
  }
  s3: "Historical bugs" {
    style: { fill: white; stroke: "#DC2626"; stroke-width: 2; font-color: "#991B1B"; border-radius: 6 }
  }
}

step2: "" {
  grid-rows: 4
  grid-gap: 8
  style: {
    fill: "#FEF3C7"; stroke: "#D97706"; stroke-width: 3
    border-radius: 12
  }

  title: "Programmatic Oracle" {
    shape: text
    style: { font-color: "#92400E"; bold: true }
  }
  s1: "Static checkers" {
    style: { fill: white; stroke: "#D97706"; stroke-width: 2; font-color: "#92400E"; border-radius: 6 }
  }
  s2: "Dynamic checkers" {
    style: { fill: white; stroke: "#D97706"; stroke-width: 2; font-color: "#92400E"; border-radius: 6 }
  }
  s3: "Aggregate verdict" {
    style: { fill: white; stroke: "#FCD34D"; stroke-width: 2; font-color: "#B45309"; border-radius: 6 }
  }
}

step3: "" {
  grid-rows: 4
  grid-gap: 8
  style: {
    fill: "#DBEAFE"; stroke: "#2563EB"; stroke-width: 3
    border-radius: 12
  }

  title: "LLM × Coverage Loop" {
    shape: text
    style: { font-color: "#1D4ED8"; bold: true }
  }
  s1: "Filter defense-related code" {
    style: { fill: white; stroke: "#2563EB"; stroke-width: 2; font-color: "#1D4ED8"; border-radius: 6 }
  }
  s2: "Pick target basic block" {
    style: { fill: white; stroke: "#2563EB"; stroke-width: 2; font-color: "#1D4ED8"; border-radius: 6 }
  }
  s3: "LLM constraint solving (mutation)" {
    style: { fill: white; stroke: "#2563EB"; stroke-width: 2; font-color: "#1D4ED8"; border-radius: 6 }
  }
}

step4: "" {
  grid-rows: 3
  grid-gap: 8
  style: {
    fill: "#DCFCE7"; stroke: "#16A34A"; stroke-width: 3
    border-radius: 12
  }

  title: "Defense Bugs" {
    shape: text
    style: { font-color: "#166534"; bold: true }
  }
  s1: "Reported upstream" {
    style: { fill: white; stroke: "#16A34A"; stroke-width: 2; font-color: "#166534"; border-radius: 6 }
  }
  s2: "Confirmed / patch" {
    style: { fill: white; stroke: "#16A34A"; stroke-width: 2; font-color: "#166534"; border-radius: 6 }
  }
}

step1 -> step2: "supplies\nsafety contract" {
  style: { stroke: "#DC2626"; stroke-width: 3; font-color: "#991B1B"; bold: true }
}
step2 -> step3: "supplies\nverdict API" {
  style: { stroke: "#D97706"; stroke-width: 3; font-color: "#92400E"; bold: true }
}
step3 -> step4: "drives to\nfailure path" {
  style: { stroke: "#2563EB"; stroke-width: 3; font-color: "#1D4ED8"; bold: true }
}
