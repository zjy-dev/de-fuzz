# Figure 3 — research content dependency chain (English)
# render: d2 --layout=dagre --pad=24 pipeline.en.d2 pipeline.en.svg

direction: right

step1: "" {
  grid-rows: 4
  grid-gap: 8
  style: {
    fill: "#F4DFD8"; stroke: "#CC3311"; stroke-width: 3
    border-radius: 12
  }

  title: "Defense Invariants" {
    shape: text
    style: { font-color: "#7F2615"; bold: true }
  }
  s1: "Official docs" {
    style: { fill: white; stroke: "#CC3311"; stroke-width: 2; font-color: "#7F2615"; border-radius: 6 }
  }
  s2: "Source comments" {
    style: { fill: white; stroke: "#CC3311"; stroke-width: 2; font-color: "#7F2615"; border-radius: 6 }
  }
  s3: "Historical bugs" {
    style: { fill: white; stroke: "#CC3311"; stroke-width: 2; font-color: "#7F2615"; border-radius: 6 }
  }
}

step2: "" {
  grid-rows: 4
  grid-gap: 8
  style: {
    fill: "#F6F1D8"; stroke: "#CCBB44"; stroke-width: 3
    border-radius: 12
  }

  title: "Programmatic Oracle" {
    shape: text
    style: { font-color: "#7A6F1D"; bold: true }
  }
  s1: "Static checkers" {
    style: { fill: white; stroke: "#CCBB44"; stroke-width: 2; font-color: "#7A6F1D"; border-radius: 6 }
  }
  s2: "Dynamic checkers" {
    style: { fill: white; stroke: "#CCBB44"; stroke-width: 2; font-color: "#7A6F1D"; border-radius: 6 }
  }
  s3: "Aggregate verdict" {
    style: { fill: white; stroke: "#CCBB44"; stroke-width: 2; font-color: "#7A6F1D"; border-radius: 6 }
  }
}

step3: "" {
  grid-rows: 4
  grid-gap: 8
  style: {
    fill: "#E6EDF5"; stroke: "#4477AA"; stroke-width: 3
    border-radius: 12
  }

  title: "LLM × Coverage Loop" {
    shape: text
    style: { font-color: "#2F557F"; bold: true }
  }
  s1: "Filter defense-related code" {
    style: { fill: white; stroke: "#4477AA"; stroke-width: 2; font-color: "#2F557F"; border-radius: 6 }
  }
  s2: "Pick target basic block" {
    style: { fill: white; stroke: "#4477AA"; stroke-width: 2; font-color: "#2F557F"; border-radius: 6 }
  }
  s3: "LLM constraint solving (mutation)" {
    style: { fill: white; stroke: "#4477AA"; stroke-width: 2; font-color: "#2F557F"; border-radius: 6 }
  }
}

step4: "" {
  grid-rows: 3
  grid-gap: 8
  style: {
    fill: "#E3F1E7"; stroke: "#228833"; stroke-width: 3
    border-radius: 12
  }

  title: "Defense Bugs" {
    shape: text
    style: { font-color: "#195C24"; bold: true }
  }
  s1: "Reported upstream" {
    style: { fill: white; stroke: "#228833"; stroke-width: 2; font-color: "#195C24"; border-radius: 6 }
  }
  s2: "Confirmed / patch" {
    style: { fill: white; stroke: "#228833"; stroke-width: 2; font-color: "#195C24"; border-radius: 6 }
  }
}

step1 -> step2: "supplies\nsafety contract" {
  style: { stroke: "#CC3311"; stroke-width: 3; font-color: "#7F2615"; bold: true }
}
step2 -> step3: "supplies\nverdict API" {
  style: { stroke: "#CCBB44"; stroke-width: 3; font-color: "#7A6F1D"; bold: true }
}
step3 -> step4: "drives to\nfailure path" {
  style: { stroke: "#4477AA"; stroke-width: 3; font-color: "#2F557F"; bold: true }
}
