# 图 4 — DeFuzz 总体架构（中文版）
# 渲染：d2 --layout=elk --pad=24 architecture.zh.d2 architecture.zh.svg
# 节点收紧：仅保留 引擎 / 编译器 / 大模型 / 预言机 / 语料库 / 调度器 6 个核心模块。

direction: right

engine: "Fuzz 引擎\n（主循环 · 提示词组装）" {
  style: {
    fill: "#DBEAFE"; stroke: "#3B82F6"; stroke-width: 3
    font-color: "#1E3A8A"; border-radius: 8; bold: true
  }
}

llm: "大模型" {
  shape: cloud
  style: {
    fill: "#EDE9FE"; stroke: "#7C3AED"; stroke-width: 2
    font-color: "#4C1D95"; bold: true
  }
}

compiler: "编译器子系统\n（GCC / LLVM · 覆盖率插桩）" {
  style: {
    fill: "#DCFCE7"; stroke: "#16A34A"; stroke-width: 2
    font-color: "#14532D"; border-radius: 8
  }
}

oracle: "预言机子系统\n（静态 · 动态 · 聚合）" {
  style: {
    fill: "#FEF3C7"; stroke: "#D97706"; stroke-width: 2
    font-color: "#78350F"; border-radius: 8
  }
}

corpus: "种子语料库" {
  shape: cylinder
  style: {
    fill: "#F4F8FB"; stroke: "#6B7280"; stroke-width: 2
    font-color: "#374151"; bold: true
  }
}

scheduler: "策略调度器\n（架构 · 编译选项 · flag profile）" {
  style: {
    fill: "#FFEDD5"; stroke: "#EA580C"; stroke-width: 2
    font-color: "#7C2D12"; border-radius: 8
  }
}

engine -> llm: "提示词" { style: { stroke: "#7C3AED"; stroke-width: 2 } }
llm -> engine: "新种子" { style: { stroke: "#7C3AED"; stroke-width: 2 } }

engine -> compiler: "编译 + 覆盖率" { style: { stroke: "#16A34A"; stroke-width: 2 } }
compiler -> engine: "覆盖率反馈" { style: { stroke: "#16A34A"; stroke-width: 2; stroke-dash: 4 } }

engine -> oracle: "二进制 + flag profile" { style: { stroke: "#D97706"; stroke-width: 2 } }
oracle -> engine: "判定结果" { style: { stroke: "#D97706"; stroke-width: 2; stroke-dash: 4 } }

engine -> corpus: "持久化" { style: { stroke: "#6B7280"; stroke-width: 2 } }

scheduler -> compiler: "工具链 / flag" { style: { stroke: "#EA580C"; stroke-width: 2; stroke-dash: 5 } }
scheduler -> oracle: "flag 配置" { style: { stroke: "#EA580C"; stroke-width: 2; stroke-dash: 5 } }
