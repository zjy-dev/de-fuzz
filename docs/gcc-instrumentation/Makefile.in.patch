# GCC Makefile.in Instrumentation Patch
# =====================================
# This file documents the patch pattern used by DeFuzz to add selective
# coverage and CFG dump instrumentation to GCC's Makefile.in.
#
# Current repository status:
# - the checked-in GCC 15.2 cross builds already use a validated multi-file
#   whitelist rather than a cfgexpand-only whitelist
# - each object in the whitelist corresponds to one compiler source file that
#   can later contribute a real *.cfg dump to cfg_file_paths
#
# How to apply:
# 1. Locate the lines mentioned in each section
# 2. Insert/modify the code blocks as shown
#
# Target file: gcc/Makefile.in (in GCC source tree)

# ============================================================================
# SECTION 1: After line ~163 (after "coverageexts = .{gcda,gcno}")
# Insert the following block:
# ============================================================================

# ====================================================================
# FUZZ-COVERAGE-INSTRUMENTATION-1: Selective Coverage Whitelist
# ====================================================================
# Selective coverage: only instrument specific files to reduce overhead.
# IMPORTANT:
# every compiler source file you want the analyzer to actively target needs its
# own object entry here, otherwise no matching *.cfg will be generated.
COVERAGE_WHITELIST = cfgexpand.o function.o calls.o targhooks.o builtins.o gimple-fold.o c-family/c-opts.o linux.o aarch64.o riscv.o

# Function to determine if a target should use coverage flags
# Returns COVERAGE_FLAGS if the target is in whitelist, empty otherwise
coverage-for = $(if $(filter $(1),$(COVERAGE_WHITELIST)),$(COVERAGE_FLAGS),)

# Per-file coverage flags (empty by default, overridden for whitelisted files)
CFLAGS-cfgexpand.o = $(COVERAGE_FLAGS)
CFLAGS-function.o = $(COVERAGE_FLAGS)
CFLAGS-calls.o = $(COVERAGE_FLAGS)
CFLAGS-targhooks.o = $(COVERAGE_FLAGS)
CFLAGS-builtins.o = $(COVERAGE_FLAGS)
CFLAGS-gimple-fold.o = $(COVERAGE_FLAGS)
CFLAGS-c-family/c-opts.o = $(COVERAGE_FLAGS)
CFLAGS-linux.o = $(COVERAGE_FLAGS)
CFLAGS-aarch64.o = $(COVERAGE_FLAGS)
CFLAGS-riscv.o = $(COVERAGE_FLAGS)

# CFG Dump flags for static analysis (control flow graph generation)
# This enables CFG dump for specific files to support CFG-guided fuzzing
CFG_DUMP_WHITELIST = $(COVERAGE_WHITELIST)
CFG_DUMP_FLAGS = -fdump-tree-cfg-lineno

# Per-file CFG dump flags
CFLAGS-cfgexpand.o += $(CFG_DUMP_FLAGS)
CFLAGS-function.o += $(CFG_DUMP_FLAGS)
CFLAGS-calls.o += $(CFG_DUMP_FLAGS)
CFLAGS-targhooks.o += $(CFG_DUMP_FLAGS)
CFLAGS-builtins.o += $(CFG_DUMP_FLAGS)
CFLAGS-gimple-fold.o += $(CFG_DUMP_FLAGS)
CFLAGS-c-family/c-opts.o += $(CFG_DUMP_FLAGS)
CFLAGS-linux.o += $(CFG_DUMP_FLAGS)
CFLAGS-aarch64.o += $(CFG_DUMP_FLAGS)
CFLAGS-riscv.o += $(CFG_DUMP_FLAGS)
# ====================================================================


# ============================================================================
# SECTION 2: Around line ~1066 (replace the ALL_CFLAGS and ALL_CXXFLAGS definitions)
# Original:
#   ALL_CFLAGS = $(T_CFLAGS) $(CFLAGS) $(INTERNAL_CFLAGS) $(COVERAGE_FLAGS) ...
# Replace with:
# ============================================================================

# ====================================================================
# FUZZ-COVERAGE-INSTRUMENTATION-2: Selective CFLAGS Application
# ====================================================================
# This is the variable actually used when we compile. If you change this,
# you probably want to update BUILD_CFLAGS in configure.ac
# NOTE: COVERAGE_FLAGS is now applied selectively via CFLAGS-$@ for whitelisted files only
ALL_CFLAGS = $(T_CFLAGS) $(CFLAGS-$@) \
  $(CFLAGS) $(INTERNAL_CFLAGS) $(WARN_CFLAGS) @DEFS@

# The C++ version.
# NOTE: COVERAGE_FLAGS is now applied selectively via CFLAGS-$@ for whitelisted files only
ALL_CXXFLAGS = $(T_CFLAGS) $(CFLAGS-$@) $(CXXFLAGS) $(INTERNAL_CFLAGS) \
  $(ALIASING_FLAGS) $(NOEXCEPTION_FLAGS) \
  $(WARN_CXXFLAGS) @DEFS@
# ====================================================================


# ============================================================================
# SECTION 3: Around line ~1089 (replace/modify ALL_LINKERFLAGS definition)
# Original:
#   ALL_LINKERFLAGS = $(ALL_CXXFLAGS)
# Replace with:
# ============================================================================

# ====================================================================
# FUZZ-COVERAGE-INSTRUMENTATION-3: Coverage Linker Flags
# ====================================================================
# This is the variable to use when using $(LINKER).
# NOTE: Add coverage linker flags to link libgcov when any object has coverage instrumentation
ALL_LINKERFLAGS = $(ALL_CXXFLAGS) $(COVERAGE_LDFLAGS)

# Coverage linker flags - needed when linking executables with coverage-instrumented objects
COVERAGE_LDFLAGS = -lgcov --coverage
# ====================================================================


# ============================================================================
# NOTES:
# ============================================================================
# 
# 1. The key insight is using $(CFLAGS-$@) which expands to target-specific flags
#    For each whitelisted object, it expands to:
#      $(COVERAGE_FLAGS) -fdump-tree-cfg-lineno
#    For other targets, it expands to empty string
#
# 2. Search for "FUZZ-COVERAGE-INSTRUMENTATION" to find all modified sections
#
# 3. To add more files to instrumentation, add them to:
#    - COVERAGE_WHITELIST (for coverage)
#    - CFG_DUMP_WHITELIST (for CFG dump)
#    And add corresponding CFLAGS-xxx.o lines
#
#    Rule of thumb:
#    one source file you want to target => one object in the whitelist
#    => one generated .cfg dump during the compiler build.
#
# 4. linux.o maps to gcc/gcc/config/linux.cc.
#    aarch64.o maps to gcc/gcc/config/aarch64/aarch64.cc.
#    riscv.o maps to gcc/gcc/config/riscv/riscv.cc.
#    If you later need backend-specific LoongArch CFGs, you must add the
#    corresponding LoongArch object explicitly as well.
#
# 5. After changing the whitelist or CFG flags:
#    - rebuild the affected objects
#    - relink cc1
#    Rebuilding only the *.o without relinking cc1 is insufficient.
